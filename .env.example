# ─────────────────────────────────────────────────────────
# Agent d'Évaluation de Candidatures RH — Configuration
# ─────────────────────────────────────────────────────────
# Copier ce fichier en .env et renseigner les valeurs

# ── LLM : GroqCloud ──────────────────────────────────────
GROQ_API_KEY=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
GROQ_MODEL=llama-3.3-70b-versatile

# ── Embeddings : Ollama local ─────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=mxbai-embed-large

# ── Base de données : PostgreSQL ──────────────────────────
POSTGRES_USER=hr_agent
POSTGRES_PASSWORD=hr_agent_pass
POSTGRES_DB=hr_agent_db
DATABASE_URL=postgresql+asyncpg://hr_agent:hr_agent_pass@localhost:5432/hr_agent_db

# ── LangSmith (Observabilité LangGraph) ──────────────────
LANGCHAIN_TRACING_V2=true
LANGSMITH_API_KEY=lsv2_your_langsmith_api_key_here
LANGSMITH_PROJECT=hr-agent-evaluateur
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── ChromaDB ─────────────────────────────────────────────
CHROMA_PERSIST_DIR=/app/chroma_db

# ── Fichiers uploadés ─────────────────────────────────────
UPLOAD_DIR=/app/data/uploads
MAX_FILE_SIZE_MB=10

# ── Sécurité ──────────────────────────────────────────────
SECRET_KEY=change_this_to_a_random_secret_key_min_32_chars
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
