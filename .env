# ─────────────────────────────────────────────────────────
# Agent d'Évaluation de Candidatures RH — Configuration
# ─────────────────────────────────────────────────────────

# ── LLM : GroqCloud ──────────────────────────────────────
GROQ_API_KEY=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
GROQ_MODEL=qwen/qwen3-32b

# ── Embeddings : sentence-transformers (local, sans serveur) ──
EMBED_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ── ChromaDB (vector store local) ────────────────────────
CHROMA_PERSIST_DIR=/app/chroma_db

# ── Base de données : PostgreSQL ──────────────────────────
POSTGRES_USER=hr_agent
POSTGRES_PASSWORD=hr_agent_pass
POSTGRES_DB=hr_agent_db
DATABASE_URL=postgresql+asyncpg://hr_agent:hr_agent_pass@localhost:5432/hr_agent_db

# ── LangSmith (Observabilité LangGraph) ──────────────────
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=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
LANGSMITH_PROJECT="hr-agent-evaluateur"

# ── Fichiers uploadés ─────────────────────────────────────
UPLOAD_DIR=/app/data/uploads
MAX_FILE_SIZE_MB=10

# ── Sécurité ──────────────────────────────────────────────
SECRET_KEY=change_this_to_a_random_secret_key_min_32_chars
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
